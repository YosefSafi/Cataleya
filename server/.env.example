# Server
PORT=8080
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Database (local dev via docker-compose, or Azure Database for PostgreSQL in prod)
DATABASE_URL=postgres://cattleya:cattleya@localhost:5432/cattleya

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
OTP_EXPIRES_MINUTES=10
RESET_TOKEN_EXPIRES_MINUTES=30

# Email (Azure Communication Services). Leave EMAIL_PROVIDER=console to log emails
# to the server console instead of sending them, for local dev without ACS provisioned.
EMAIL_PROVIDER=console
ACS_CONNECTION_STRING=
ACS_SENDER_ADDRESS=

# File uploads (Azure Blob Storage). Leave STORAGE_PROVIDER=local to write to
# server/uploads instead, for local dev without a storage account provisioned.
STORAGE_PROVIDER=local
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=lab-results

# Google OAuth — deferred to a second release, routes are commented out in
# src/routes/auth.js. Leave these blank.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

# Crypto checkout (Coinbase Commerce: https://beta.commerce.coinbase.com/settings/security).
# Leave CRYPTO_PROVIDER=stub (or unset) to use a local fake checkout page instead — lets you
# exercise the full order flow without a real Coinbase account. Set to "coinbase" + fill in
# the two values below to go live.
CRYPTO_PROVIDER=stub
COINBASE_COMMERCE_API_KEY=
COINBASE_COMMERCE_WEBHOOK_SECRET=

# Zelle payment instructions shown to the customer at checkout (manual confirmation —
# no API exists for Zelle; you mark orders paid directly in the database once you see
# the money land).
ZELLE_RECIPIENT_EMAIL=payments@cattleyalabs.com
ZELLE_RECIPIENT_NAME=Cattleya Labs
